/* PkgLnk Window - Base Styles (Dark / Jade Theme) */
/* Color scheme from pkglnk.dev */

.pkglnk-window {
    padding: 0;
    flex-grow: 1;
    background-color: #022c22;
}

.package-browser {
    flex-grow: 1;
    flex-direction: column;
}

.list-view {
    flex-grow: 1;
    flex-direction: column;
}

/* Header bar */
.header-bar {
    position: relative;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background-color: rgba(4, 53, 42, 0.95);
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.08);
    min-height: 40px;
    overflow: visible;
}

.header-brand-row {
    flex-direction: row;
    align-items: center;
}

.header-logo {
    width: 20px;
    height: 20px;
    margin-right: 6px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: #10b981;
}

.header-brand {
    font-size: 14px;
    -unity-font-style: bold;
    color: #ecfdf5;
}

.header-version {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.3);
    margin-left: 6px;
    padding-top: 2px;
    -unity-text-align: middle-left;
}

.header-version-update {
    color: #10b981;
    -unity-font-style: bold;
}

.header-auth-row {
    flex-direction: row;
    align-items: center;
}

.sign-in-button {
    height: 24px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 11px;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    -unity-text-align: middle-center;
}

.sign-in-button:hover {
    background-color: #059669;
}

/* Profile button */
.profile-button {
    flex-direction: row;
    align-items: center;
    height: 28px;
    padding: 2px 8px 2px 2px;
    border-radius: 14px;
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.profile-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.header-avatar {
    width: 22px;
    height: 22px;
    border-radius: 11px;
    border-width: 2px;
    border-color: #10b981;
    margin-right: 6px;
    -unity-background-scale-mode: scale-and-crop;
    flex-shrink: 0;
}

.header-username {
    font-size: 11px;
    color: #a7f3d0;
    max-width: 120px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.profile-chevron {
    font-size: 10px;
    color: rgba(110, 231, 183, 0.5);
    margin-left: 2px;
}

/* Profile dropdown */
.profile-dropdown {
    position: absolute;
    top: 40px;
    right: 12px;
    min-width: 140px;
    background-color: #064e3b;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 4px;
    overflow: hidden;
    z-index: 9999;
}

.profile-dropdown-item {
    height: 28px;
    padding: 0 10px;
    border-radius: 6px;
    font-size: 11px;
    background-color: rgba(0, 0, 0, 0);
    color: #a7f3d0;
    border-width: 0;
    -unity-text-align: middle-left;
}

.profile-dropdown-item:hover {
    background-color: rgba(255, 255, 255, 0.08);
}

.profile-dropdown-item-danger {
    color: #f87171;
}

.profile-dropdown-item-danger:hover {
    background-color: rgba(248, 113, 113, 0.1);
}

/* Tab bar */
.tab-bar {
    flex-direction: row;
    padding: 0 12px;
    background-color: #04352a;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.08);
}

.tab-button {
    flex-direction: row;
    align-items: center;
    padding: 8px 14px;
    font-size: 11px;
    color: #6ee7b7;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-bottom-width: 2px;
    border-bottom-color: rgba(0, 0, 0, 0);
    border-radius: 0;
}

.tab-icon {
    width: 14px;
    height: 14px;
    margin-right: 4px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: #6ee7b7;
}

.tab-label {
    font-size: 11px;
    color: #6ee7b7;
}

.tab-button:hover {
    color: #a7f3d0;
    background-color: rgba(255, 255, 255, 0.03);
}

.tab-button:hover .tab-icon {
    -unity-background-image-tint-color: #a7f3d0;
}

.tab-button:hover .tab-label {
    color: #a7f3d0;
}

.tab-button:disabled {
    color: rgba(110, 231, 183, 0.3);
}

.tab-button:disabled .tab-icon {
    -unity-background-image-tint-color: rgba(110, 231, 183, 0.3);
}

.tab-button:disabled .tab-label {
    color: rgba(110, 231, 183, 0.3);
}

.tab-button-active {
    color: #10b981;
    border-bottom-color: #10b981;
}

.tab-button-active .tab-icon {
    -unity-background-image-tint-color: #10b981;
}

.tab-button-active .tab-label {
    color: #10b981;
}

/* Search bar */
.search-row {
    flex-direction: row;
    padding: 8px 12px;
    min-height: 36px;
    align-items: center;
    background-color: #04352a;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.08);
}

.search-field {
    flex-grow: 1;
    margin-right: 4px;
}

.search-field > .unity-text-field__input {
    background-color: #022c22;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: #ecfdf5;
    padding: 4px 8px;
}

.search-field > .unity-text-field__input:focus {
    border-color: #10b981;
}

.clear-search-button {
    width: 24px;
    height: 24px;
    font-size: 16px;
    -unity-font-style: bold;
    background-color: rgba(255, 255, 255, 0.03);
    color: #6ee7b7;
    border-radius: 8px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    padding: 0;
    -unity-text-align: middle-center;
}

.clear-search-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
}

/* Status label */
.status-label {
    -unity-text-align: middle-center;
    padding: 20px;
    color: #6ee7b7;
    font-size: 12px;
    -unity-font-style: italic;
}

/* Package list scroll */
.package-list-scroll {
    flex-grow: 1;
    background-color: #022c22;
}

.package-card-container {
    position: relative;
}

/* Package card */
.package-card {
    position: absolute;
    overflow: hidden;
    border-radius: 12px;
    padding: 0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    background-color: #064e3b;
}

.package-card:hover {
    background-color: rgba(16, 185, 129, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.package-card-installed {
    border-color: rgba(34, 197, 94, 0.35);
}

.card-body {
    padding: 12px;
    flex-grow: 1;
}

/* Card header */
.card-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
}

.owner-row {
    flex-direction: row;
    align-items: center;
}

.owner-avatar {
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.15);
    margin-right: 4px;
    -unity-background-scale-mode: scale-and-crop;
    flex-shrink: 0;
}

.owner-name {
    font-size: 11px;
    color: #6ee7b7;
}

.install-count-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    color: #a7f3d0;
}

.bookmark-button {
    width: 22px;
    height: 22px;
    padding: 0;
    margin-left: 4px;
    border-radius: 4px;
    border-width: 0;
    background-color: rgba(0, 0, 0, 0);
    align-items: center;
    justify-content: center;
}

.bookmark-button:hover {
    background-color: rgba(110, 231, 183, 0.1);
}

.bookmark-icon {
    width: 14px;
    height: 14px;
    -unity-background-image-tint-color: rgba(110, 231, 183, 0.4);
    -unity-background-scale-mode: scale-to-fit;
}

.bookmark-button:hover .bookmark-icon {
    -unity-background-image-tint-color: #6ee7b7;
}

.bookmark-button-active .bookmark-icon {
    -unity-background-image-tint-color: #10b981;
}

.bookmark-button-active:hover .bookmark-icon {
    -unity-background-image-tint-color: #059669;
}

/* Card image area */
.card-image-area {
    width: 100%;
    min-height: 80px;
    flex-grow: 1;
    border-radius: 8px;
    margin-bottom: 8px;
    background-color: #04352a;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.card-image {
    width: 100%;
    height: 100%;
    -unity-background-scale-mode: scale-to-fit;
}

.card-image-placeholder {
    width: 36px;
    height: 36px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: rgba(110, 231, 183, 0.2);
}

/* Card text */
.package-display-name {
    font-size: 13px;
    -unity-font-style: bold;
    color: #ecfdf5;
    margin-bottom: 3px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.package-description {
    font-size: 11px;
    color: #a7f3d0;
    margin-bottom: 6px;
    white-space: normal;
    min-height: 56px;
    max-height: 56px;
    overflow: hidden;
}

.package-description-empty {
    -unity-font-style: italic;
    color: #6ee7b7;
    opacity: 0.5;
}

/* Topics */
.topic-tags-row {
    flex-direction: row;
    flex-wrap: nowrap;
    overflow: hidden;
    margin-bottom: 6px;
}

.topic-tags-inner {
    position: relative;
    flex-direction: row;
    flex-wrap: nowrap;
    flex-shrink: 0;
}

.topic-tag {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-right: 4px;
    margin-bottom: 3px;
    color: #6ee7b7;
    flex-shrink: 0;
    flex-grow: 0;
    align-self: flex-start;
}

.topic-tag:hover {
    background-color: rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.3);
    color: #a7f3d0;
}

/* Card footer */
.card-footer {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding-top: 8px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.08);
}

.card-platform-icon {
    width: 12px;
    height: 12px;
    margin-right: 4px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: #6ee7b7;
}

.repo-label {
    font-size: 10px;
    color: #6ee7b7;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    flex-grow: 1;
    flex-shrink: 1;
}

.updated-label {
    font-size: 10px;
    color: #6ee7b7;
    opacity: 0.6;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 6px;
}

/* Install button (compact, in footer) */
.install-button {
    height: 20px;
    padding: 0 10px;
    border-radius: 6px;
    font-size: 10px;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    -unity-text-align: middle-center;
    margin-left: 8px;
    flex-shrink: 0;
}

.install-button:hover {
    background-color: #059669;
}

.install-button:disabled {
    background-color: rgba(255, 255, 255, 0.03);
    color: rgba(110, 231, 183, 0.4);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.install-button-icon {
    width: 14px;
    height: 18px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: #ffffff;
}

.installed-button {
    background-color: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border-width: 1px;
    border-color: rgba(34, 197, 94, 0.3);
}

.installed-button:disabled {
    background-color: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border-width: 1px;
    border-color: rgba(34, 197, 94, 0.3);
}

/* Load more button */
.load-more-button {
    margin: 8px 12px;
    height: 28px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    -unity-text-align: middle-center;
}

.load-more-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

/* Ghost / skeleton card */
.package-card-ghost {
    border-color: rgba(255, 255, 255, 0.04);
    background-color: rgba(6, 78, 59, 0.5);
}

.ghost-body {
    padding: 12px;
    flex-grow: 1;
}

.ghost-line {
    height: 12px;
    border-radius: 6px;
    background-color: rgba(255, 255, 255, 0.06);
    margin-bottom: 10px;
}

.ghost-line-short {
    width: 30%;
}

.ghost-line-medium {
    width: 60%;
}

.ghost-line-long {
    width: 90%;
}

.ghost-image {
    min-height: 80px;
    flex-grow: 1;
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 0.04);
    margin-bottom: 10px;
}

/* Error label */
.error-label {
    -unity-text-align: middle-center;
    padding: 8px;
    color: #f87171;
    font-size: 11px;
}

/* Detail view */
.package-detail {
    flex-grow: 1;
    flex-direction: column;
    padding: 12px;
    background-color: #022c22;
}

.detail-back-button {
    width: 80px;
    height: 24px;
    margin-bottom: 12px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-radius: 8px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.detail-back-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.detail-title-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 4px;
}

.detail-title {
    font-size: 18px;
    -unity-font-style: bold;
    color: #ecfdf5;
    margin-right: 8px;
}

.detail-platform-icon {
    width: 14px;
    height: 14px;
    margin-right: 6px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: #a7f3d0;
}

.detail-platform-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    color: #a7f3d0;
}

.detail-owner {
    font-size: 12px;
    color: #6ee7b7;
    margin-bottom: 8px;
}

.detail-image-area {
    width: 100%;
    height: 140px;
    border-radius: 8px;
    margin-bottom: 10px;
    background-color: #04352a;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    overflow: hidden;
    align-items: center;
    justify-content: center;
}

.detail-stats-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 10px;
}

.detail-stat {
    font-size: 11px;
    color: #6ee7b7;
    margin-right: 16px;
}

.detail-description {
    font-size: 12px;
    white-space: normal;
    margin-bottom: 8px;
    color: #a7f3d0;
}

.detail-package-name {
    font-size: 11px;
    padding: 4px 8px;
    background-color: #04352a;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    margin-bottom: 8px;
    color: #6ee7b7;
    -unity-font-style: italic;
}

.detail-topics-row {
    margin-bottom: 10px;
}

.detail-url-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 6px;
}

.detail-install-url {
    font-size: 10px;
    padding: 4px 8px;
    background-color: #04352a;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: #6ee7b7;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-grow: 1;
    flex-shrink: 1;
}

.detail-copy-button {
    height: 24px;
    margin-left: 4px;
    font-size: 10px;
    padding: 0 10px;
    border-radius: 8px;
    flex-shrink: 0;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.detail-copy-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
}

.detail-install-button {
    height: 32px;
    border-radius: 8px;
    font-size: 13px;
    -unity-font-style: bold;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    margin-top: 8px;
    -unity-text-align: middle-center;
}

.detail-install-button:hover {
    background-color: #059669;
}

.detail-install-button:disabled {
    background-color: rgba(255, 255, 255, 0.03);
    color: rgba(110, 231, 183, 0.4);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.detail-install-button.installed-button {
    background-color: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border-width: 1px;
    border-color: rgba(34, 197, 94, 0.3);
}

.detail-install-button.installed-button:disabled {
    background-color: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border-width: 1px;
    border-color: rgba(34, 197, 94, 0.3);
}

/* Login modal */
.login-overlay {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background-color: rgba(2, 44, 34, 0.85);
    align-items: center;
    justify-content: center;
}

.login-card {
    background-color: #064e3b;
    border-radius: 12px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    padding: 24px;
    max-width: 320px;
    align-items: center;
}

.login-card-title {
    font-size: 16px;
    -unity-font-style: bold;
    color: #ecfdf5;
    margin-bottom: 8px;
}

.login-card-message {
    font-size: 12px;
    color: #a7f3d0;
    margin-bottom: 20px;
    -unity-text-align: middle-center;
    white-space: normal;
}

.login-card-button {
    width: 100%;
    height: 32px;
    border-radius: 8px;
    font-size: 13px;
    -unity-font-style: bold;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    -unity-text-align: middle-center;
    margin-bottom: 8px;
}

.login-card-button:hover {
    background-color: #059669;
}

.login-card-cancel {
    width: 100%;
    height: 28px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    -unity-text-align: middle-center;
}

.login-card-cancel:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

/* Search group (wraps search field + clear button) */
.search-group {
    flex-direction: row;
    flex-grow: 1;
    align-items: center;
}

/* Filter button */
.filter-button {
    width: 24px;
    height: 24px;
    padding: 0;
    border-radius: 8px;
    font-size: 16px;
    -unity-font-style: bold;
    background-color: rgba(255, 255, 255, 0.03);
    color: #6ee7b7;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    -unity-text-align: middle-center;
    flex-shrink: 0;
    margin-right: 4px;
}

.filter-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.filter-button-active {
    background-color: rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.3);
    color: #10b981;
}

/* Filter badge */
.filter-badge {
    position: absolute;
    top: -6px;
    right: -6px;
    min-width: 16px;
    height: 16px;
    border-radius: 8px;
    background-color: #10b981;
    color: #ffffff;
    font-size: 9px;
    -unity-text-align: middle-center;
    padding: 0 4px;
}

/* Filter dropdown */
.filter-dropdown {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    max-height: 240px;
    background-color: #04352a;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 0 0 12px 12px;
    padding: 10px 12px;
    overflow: hidden;
}

.filter-dropdown-scroll {
    flex-grow: 1;
}

.filter-close-button {
    width: 22px;
    height: 22px;
    font-size: 14px;
    -unity-font-style: bold;
    padding: 0;
    border-radius: 6px;
    border-width: 0;
    background-color: rgba(255, 255, 255, 0.03);
    color: #6ee7b7;
    -unity-text-align: middle-center;
}

.filter-close-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ecfdf5;
}

.filter-dropdown-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.filter-dropdown-title {
    font-size: 12px;
    -unity-font-style: bold;
    color: #ecfdf5;
    flex-grow: 1;
}

.filter-clear-button {
    height: 22px;
    padding: 0 10px;
    border-radius: 6px;
    font-size: 10px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #6ee7b7;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.filter-clear-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.filter-section {
    margin-bottom: 6px;
}

.filter-section-label {
    font-size: 10px;
    color: #6ee7b7;
    margin-bottom: 4px;
    -unity-font-style: bold;
}

.filter-chip-row {
    flex-direction: row;
    flex-wrap: wrap;
}

.filter-chip {
    height: 24px;
    padding: 0 10px;
    border-radius: 8px;
    font-size: 10px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-right: 4px;
    margin-bottom: 4px;
    -unity-text-align: middle-center;
}

.filter-chip:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.filter-chip-active {
    background-color: rgba(16, 185, 129, 0.2);
    border-color: rgba(16, 185, 129, 0.4);
    color: #10b981;
}

.filter-chip-disabled {
    opacity: 0.4;
}

.filter-section-hint {
    font-size: 10px;
    color: #6ee7b7;
    opacity: 0.5;
    -unity-font-style: italic;
    margin-top: 2px;
}

/* ─── Collection Card ─────────────────────────────────────────── */

.collection-card {
    position: absolute;
    overflow: hidden;
    border-radius: 12px;
    padding: 0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    background-color: #064e3b;
}

.collection-card:hover {
    background-color: rgba(16, 185, 129, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.collection-card-ghost {
    border-color: rgba(255, 255, 255, 0.04);
    background-color: rgba(6, 78, 59, 0.5);
}

.collection-name {
    font-size: 14px;
    -unity-font-style: bold;
    color: #ecfdf5;
    margin-top: 6px;
    margin-bottom: 4px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.collection-description {
    font-size: 11px;
    color: #a7f3d0;
    margin-bottom: 6px;
    white-space: normal;
    min-height: 45px;
    max-height: 45px;
    overflow: hidden;
}

.collection-package-count {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.03);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    color: #a7f3d0;
    align-self: center;
}

.collection-install-button {
    padding: 0 12px;
    height: 22px;
    font-size: 11px;
}

/* ─── Collection Detail View ──────────────────────────────────── */

.collection-detail {
    flex-grow: 1;
    flex-direction: column;
    padding: 12px;
    background-color: #022c22;
}

.collection-detail-owner-row {
    flex-direction: row;
    align-items: center;
    margin-top: 6px;
    margin-bottom: 8px;
}

.collection-detail-owner-row > .detail-owner {
    margin-bottom: 0;
    margin-right: 12px;
}

.collection-detail-count {
    font-size: 11px;
    color: #6ee7b7;
}

.collection-detail-separator {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-top: 8px;
    margin-bottom: 8px;
}

/* Install All button */
.install-all-button {
    height: 36px;
    border-radius: 8px;
    font-size: 13px;
    -unity-font-style: bold;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    margin-top: 8px;
    -unity-text-align: middle-center;
}

.install-all-button:hover {
    background-color: #059669;
}

.install-all-button:disabled {
    background-color: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border-width: 1px;
    border-color: rgba(34, 197, 94, 0.3);
}

/* Batch cancel button is still used in action row */

.batch-cancel-button {
    height: 24px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #f87171;
    border-width: 1px;
    border-color: rgba(248, 113, 113, 0.2);
    margin-top: 4px;
    align-self: flex-start;
}

.batch-cancel-button:hover {
    background-color: rgba(248, 113, 113, 0.1);
    border-color: rgba(248, 113, 113, 0.4);
}

.batch-cancel-button:disabled {
    opacity: 0.4;
}

/* Collection package scroll */
.collection-package-scroll {
    flex-grow: 1;
}

/* Collection action row */
.collection-action-row {
    flex-direction: row;
    align-items: center;
    margin-top: 8px;
}

.collection-action-row > .batch-cancel-button {
    margin-left: 8px;
}

/* Collection package row */
.collection-package-row {
    flex-direction: column;
    padding: 8px 4px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.04);
}

.collection-package-row:hover {
    background-color: rgba(255, 255, 255, 0.02);
}

.collection-package-row-installed {
    opacity: 0.8;
}

.collection-package-top-row {
    flex-direction: row;
    align-items: center;
}

.collection-package-info {
    flex-grow: 1;
    flex-shrink: 1;
    overflow: hidden;
    margin-right: 8px;
}

.collection-package-name {
    font-size: 12px;
    -unity-font-style: bold;
    color: #ecfdf5;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.collection-package-desc {
    font-size: 10px;
    color: #a7f3d0;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    margin-top: 1px;
}

/* Per-row progress bar */
.row-progress-track {
    height: 3px;
    border-radius: 2px;
    margin-top: 6px;
    background-color: rgba(255, 255, 255, 0.08);
    overflow: hidden;
}

.row-progress-fill {
    height: 100%;
    width: 0;
    border-radius: 2px;
    background-color: #10b981;
}

.row-progress-fill-failed {
    background-color: #ef4444;
}

.row-spinner {
    font-size: 11px;
    color: #6ee7b7;
    margin-right: 4px;
    flex-shrink: 0;
    width: 12px;
    -unity-text-align: middle-center;
}

.row-status-label {
    font-size: 9px;
    color: #6ee7b7;
    margin-right: 8px;
    flex-shrink: 0;
}

.row-status-error {
    color: #fca5a5;
}

/* ─── Install Confirm Window ─────────────────────────────── */

.confirm-window-root {
    padding: 20px;
    justify-content: center;
    align-items: center;
}

.confirm-section {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
    width: 100%;
}

.confirm-brand-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
}

.confirm-logo {
    width: 22px;
    height: 22px;
    margin-right: 8px;
    margin-bottom: 3px;
    -unity-background-scale-mode: scale-to-fit;
    -unity-background-image-tint-color: #10b981;
}

.confirm-slug {
    font-size: 16px;
    -unity-font-style: bold;
    color: #6ee7b7;
    margin-bottom: 4px;
}

.confirm-url {
    font-size: 10px;
    color: rgba(167, 243, 208, 0.6);
    margin-bottom: 16px;
    -unity-text-align: middle-center;
    white-space: normal;
    overflow: hidden;
    max-width: 320px;
}

.confirm-button-row {
    flex-direction: row;
    justify-content: center;
    width: 100%;
    margin-top: 4px;
}

.confirm-button-row > .login-card-cancel {
    width: 48%;
    margin-right: 4%;
    margin-bottom: 0;
}

.confirm-button-row > .login-card-button {
    width: 48%;
    margin-bottom: 0;
}

.confirm-status-row {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    margin-top: 8px;
}

.confirm-progress-track {
    width: 100%;
    height: 4px;
    margin-top: 0;
}

.confirm-close-button {
    width: 50%;
    margin-top: 16px;
}

/* ─── Collection Toggle Row ──────────────────────────────── */

.collection-toggle-row {
    flex-direction: row;
    padding: 6px 12px;
    align-items: center;
    background-color: #04352a;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.08);
}

.toggle-button {
    height: 24px;
    padding: 0 14px;
    border-radius: 12px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #6ee7b7;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-right: 4px;
    -unity-text-align: middle-center;
}

.toggle-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.toggle-button-active {
    background-color: rgba(16, 185, 129, 0.2);
    border-color: rgba(16, 185, 129, 0.4);
    color: #10b981;
}

.toggle-button-active:hover {
    background-color: rgba(16, 185, 129, 0.25);
}

.create-collection-button {
    height: 24px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 11px;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    margin-left: auto;
    -unity-text-align: middle-center;
}

.create-collection-button:hover {
    background-color: #059669;
}

/* ─── Collection Owner Actions ───────────────────────────── */

.collection-owner-actions {
    flex-direction: row;
    margin-top: 8px;
    margin-bottom: 4px;
}

.collection-edit-button {
    height: 24px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-right: 6px;
    -unity-text-align: middle-center;
}

.collection-edit-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.collection-delete-button {
    height: 24px;
    padding: 0 12px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #f87171;
    border-width: 1px;
    border-color: rgba(248, 113, 113, 0.2);
    -unity-text-align: middle-center;
}

.collection-delete-button:hover {
    background-color: rgba(248, 113, 113, 0.1);
    border-color: rgba(248, 113, 113, 0.4);
}

/* ─── Package Remove Button ──────────────────────────────── */

.package-remove-button {
    width: 22px;
    height: 22px;
    padding: 0;
    border-radius: 4px;
    font-size: 12px;
    background-color: rgba(0, 0, 0, 0);
    color: rgba(248, 113, 113, 0.5);
    border-width: 0;
    margin-left: 4px;
    flex-shrink: 0;
    -unity-text-align: middle-center;
}

.package-remove-button:hover {
    background-color: rgba(248, 113, 113, 0.1);
    color: #f87171;
}

/* ─── Add to Collection Button ───────────────────────────── */

.add-to-collection-button {
    height: 28px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-top: 6px;
    -unity-text-align: middle-center;
}

.add-to-collection-button:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

/* ─── Add to Collection Dropdown ─────────────────────────── */

.add-to-collection-dropdown {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: 320px;
    max-height: 400px;
    background-color: #064e3b;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 12px;
    overflow: hidden;
}

.add-to-collection-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.add-to-collection-title {
    font-size: 13px;
    -unity-font-style: bold;
    color: #ecfdf5;
}

.add-to-collection-close {
    width: 22px;
    height: 22px;
    font-size: 14px;
    -unity-font-style: bold;
    padding: 0;
    border-radius: 6px;
    border-width: 0;
    background-color: rgba(255, 255, 255, 0.03);
    color: #6ee7b7;
    -unity-text-align: middle-center;
}

.add-to-collection-close:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ecfdf5;
}

.add-to-collection-list {
    max-height: 260px;
    overflow: hidden;
}

.add-to-collection-loading {
    font-size: 11px;
    color: #6ee7b7;
    -unity-font-style: italic;
    padding: 8px 0;
    -unity-text-align: middle-center;
}

.add-to-collection-empty {
    font-size: 11px;
    color: #6ee7b7;
    -unity-font-style: italic;
    padding: 8px 0;
    -unity-text-align: middle-center;
}

.add-to-collection-row {
    flex-direction: row;
    align-items: center;
    padding: 6px 4px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.04);
}

.add-to-collection-info {
    flex-grow: 1;
    flex-shrink: 1;
    overflow: hidden;
    margin-right: 8px;
}

.add-to-collection-name {
    font-size: 12px;
    -unity-font-style: bold;
    color: #ecfdf5;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
}

.add-to-collection-count {
    font-size: 10px;
    color: #6ee7b7;
}

.add-to-collection-add-btn {
    height: 22px;
    padding: 0 10px;
    border-radius: 6px;
    font-size: 10px;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    flex-shrink: 0;
    -unity-text-align: middle-center;
}

.add-to-collection-add-btn:hover {
    background-color: #059669;
}

.add-to-collection-add-btn:disabled {
    background-color: rgba(255, 255, 255, 0.03);
    color: rgba(110, 231, 183, 0.4);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
}

.add-to-collection-create {
    height: 28px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-top: 8px;
    -unity-text-align: middle-center;
}

.add-to-collection-create:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

/* ─── Collection Form Window ─────────────────────────────── */

.collection-form-root {
    padding: 16px;
}

.collection-form-section {
    flex-grow: 1;
}

.collection-form-title {
    font-size: 16px;
    -unity-font-style: bold;
    color: #ecfdf5;
    margin-bottom: 16px;
}

.collection-form-field {
    margin-bottom: 12px;
}

.collection-form-label {
    font-size: 11px;
    color: #a7f3d0;
    margin-bottom: 4px;
    -unity-font-style: bold;
}

.collection-form-input {
    flex-grow: 1;
}

.collection-form-input > .unity-text-field__input {
    background-color: #022c22;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: #ecfdf5;
    padding: 4px 8px;
}

.collection-form-input > .unity-text-field__input:focus {
    border-color: #10b981;
}

.collection-form-textarea > .unity-text-field__input {
    min-height: 60px;
    white-space: normal;
}

.collection-form-slug-row {
    flex-direction: row;
    align-items: center;
}

.slug-availability-label {
    font-size: 10px;
    margin-left: auto;
    color: #6ee7b7;
}

.slug-available {
    color: #22c55e;
}

.slug-taken {
    color: #f87171;
}

.collection-form-error {
    font-size: 11px;
    color: #f87171;
    margin-bottom: 8px;
    white-space: normal;
}

.collection-form-buttons {
    flex-direction: row;
    justify-content: flex-end;
    margin-top: 8px;
}

.collection-form-cancel {
    height: 28px;
    padding: 0 16px;
    border-radius: 8px;
    font-size: 11px;
    background-color: rgba(255, 255, 255, 0.03);
    color: #a7f3d0;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    margin-right: 6px;
    -unity-text-align: middle-center;
}

.collection-form-cancel:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
}

.collection-form-submit {
    height: 28px;
    padding: 0 16px;
    border-radius: 8px;
    font-size: 11px;
    -unity-font-style: bold;
    background-color: #10b981;
    color: #ffffff;
    border-width: 0;
    -unity-text-align: middle-center;
}

.collection-form-submit:hover {
    background-color: #059669;
}

.collection-form-saving {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
}

.collection-form-saving-label {
    font-size: 13px;
    color: #6ee7b7;
    -unity-font-style: italic;
}

/* Theme toggle — inline in header auth row */
.theme-toggle {
    width: 28px;
    height: 28px;
    padding: 0;
    margin-left: 6px;
    border-radius: 14px;
    background-color: rgba(255, 255, 255, 0.06);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.12);
    align-items: center;
    justify-content: center;
}

.theme-toggle:hover {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.2);
}

.theme-toggle-icon {
    width: 20px;
    height: 20px;
    -unity-background-scale-mode: scale-to-fit;
}

/* ─── README ────────────────────────────────────────────────── */

.detail-readme-scroll {
    flex-grow: 1;
    margin-top: 12px;
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.08);
}

.detail-readme-title {
    font-size: 16px;
    -unity-font-style: bold;
    color: #ecfdf5;
    padding: 12px 0 8px 0;
}

.detail-readme-loading {
    font-size: 11px;
    color: #6ee7b7;
    -unity-font-style: italic;
    padding: 12px 0;
    -unity-text-align: middle-center;
}

.detail-readme {
    padding-top: 0;
}

.readme-content {
    flex-direction: column;
}

.readme-heading {
    -unity-font-style: bold;
    color: #ecfdf5;
    margin-top: 16px;
    margin-bottom: 8px;
    white-space: normal;
}

.readme-h1 {
    font-size: 20px;
    margin-top: 20px;
    padding-bottom: 6px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.08);
}

.readme-h2 {
    font-size: 17px;
    margin-top: 18px;
    padding-bottom: 4px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.06);
}

.readme-h3 {
    font-size: 15px;
}

.readme-h4 {
    font-size: 13px;
}

.readme-h5 {
    font-size: 12px;
}

.readme-h6 {
    font-size: 11px;
    color: #6ee7b7;
}

.readme-paragraph {
    font-size: 12px;
    color: #a7f3d0;
    white-space: normal;
    margin-bottom: 8px;
}

.readme-code-block {
    font-size: 11px;
    color: #a7f3d0;
    background-color: #04352a;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 10px 12px;
    margin-top: 4px;
    margin-bottom: 8px;
    white-space: normal;
    overflow: hidden;
}

.readme-list {
    margin-bottom: 8px;
    padding-left: 8px;
}

.readme-list-item {
    font-size: 12px;
    color: #a7f3d0;
    white-space: normal;
    margin-bottom: 2px;
    padding-left: 4px;
}

.readme-blockquote {
    font-size: 12px;
    color: #6ee7b7;
    border-left-width: 3px;
    border-left-color: rgba(255, 255, 255, 0.15);
    padding-left: 12px;
    margin-top: 4px;
    margin-bottom: 8px;
    white-space: normal;
}

.readme-hr {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    margin-top: 12px;
    margin-bottom: 12px;
}

.readme-table {
    margin-top: 4px;
    margin-bottom: 8px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    overflow: hidden;
}

.readme-table-row {
    flex-direction: row;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.06);
}

.readme-table-header-row {
    background-color: rgba(255, 255, 255, 0.04);
}

.readme-table-header-cell {
    font-size: 11px;
    -unity-font-style: bold;
    color: #ecfdf5;
    padding: 6px 10px;
    flex-grow: 1;
    flex-basis: 0;
    white-space: normal;
}

.readme-table-cell {
    font-size: 11px;
    color: #a7f3d0;
    padding: 6px 10px;
    flex-grow: 1;
    flex-basis: 0;
    white-space: normal;
}

.readme-image-container {
    margin-top: 4px;
    margin-bottom: 8px;
}

.readme-image {
    -unity-background-scale-mode: scale-to-fit;
    max-width: 600px;
}
